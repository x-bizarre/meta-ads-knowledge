# Secrets — NEVER commit these
.env
.env.*
*.token
*secret*
*.key
*.pem
credentials.json

# Personal data exports (Ads Manager / analytics)
*.csv
report*.csv
export*.csv

# BUT the sample data is part of the project — it must be committed
# (these negation rules re-include it despite the *.csv rule above)
!analytics/sample_data/
!analytics/sample_data/*.csv

# Filled-in comms strategy — may contain real business data, keep it local
comms-*.md

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# OS
.DS_Store
